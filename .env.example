# DexThemes environment variables
# Copy this to .env.local and fill in your values

# Convex deployment URL (required for backend features)
CONVEX_URL=https://your-deployment.convex.cloud

# OAuth — GitHub (set these in your Convex deployment environment)
# GITHUB_CLIENT_ID=your_github_oauth_app_client_id
# GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# MCP OAuth resource server (set matching values in Vercel and Convex)
# Use an OAuth 2.1 provider such as Auth0 with GitHub as the upstream connection.
# DEXTHEMES_AUTH_ISSUER=https://your-tenant.us.auth0.com/
# DEXTHEMES_AUTH_AUDIENCE=https://www.dexthemes.com/api/mcp
# DEXTHEMES_AUTH_JWKS_URI=https://your-tenant.us.auth0.com/.well-known/jwks.json
# DEXTHEMES_CONFIRMATION_SECRET=at_least_32_random_characters_for_review_tokens

# OpenAI plugin domain verification (set only to the exact portal challenge)
# OPENAI_APPS_CHALLENGE=portal_provided_token

# Auth0 token configuration for the optional employee achievement:
# include standard email + email_verified claims in the signed access token.
# Never copy or persist the email in DexThemes; only the derived eligibility
# boolean is stored after exact-domain verification.

# OAuth — X/Twitter (set these in your Convex deployment environment)
# X_CLIENT_ID=your_x_oauth_client_id
# X_CLIENT_SECRET=your_x_oauth_client_secret

# Session signing secret (set in Convex deployment environment)
# SESSION_SECRET=a_random_64_char_hex_string

# Statsig (optional, for analytics)
# STATSIG_CLIENT_KEY=your_statsig_client_key
