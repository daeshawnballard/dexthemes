{
  "name": "dexthemes-build-week-video",
  "version": "1.0.0",
  "description": "Reproducible Remotion edit for the DexThemes OpenAI Build Week demo.",
  "repository": "https://github.com/daeshawnballard/dexthemes",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.490",
    "@remotion/media": "4.0.490",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.490"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.490",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.39.5",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle",
    "render:previs": "remotion render BuildWeekDemo out/dexthemes-build-week-previs.mp4 --codec=h264 --scale=0.5",
    "render:still": "remotion still BuildWeekDemo out/dexthemes-build-week-review.png --frame=2670 --scale=0.5",
    "upgrade": "remotion upgrade",
    "lint": "eslint src && tsc"
  },
  "sideEffects": [
    "*.css"
  ]
}
